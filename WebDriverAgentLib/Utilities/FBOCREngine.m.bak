#import "FBOCREngine.h"
#import <Vision/Vision.h>

@implementation FBOCRTextResult

- (instancetype)initWithText:(NSString *)text
                  confidence:(float)confidence
                        rect:(CGRect)rect {
  self = [super init];
  if (self) {
    _text = [text copy];
    _confidence = confidence;
    _rect = rect;
  }
  return self;
}

- (NSDictionary *)toDictionary {
  return @{
    @"text" : self.text ?: @"",
    @"confidence" : @(self.confidence),
    @"x" : @(self.rect.origin.x),
    @"y" : @(self.rect.origin.y),
    @"width" : @(self.rect.size.width),
    @"height" : @(self.rect.size.height)
  };
}

@end

@implementation FBOCREngine

+ (instancetype)sharedEngine {
  static FBOCREngine *sharedInstance = nil;
  static dispatch_once_t onceToken;
  dispatch_once(&onceToken, ^{
    sharedInstance = [[FBOCREngine alloc] init];
  });
  return sharedInstance;
}

- (NSArray<FBOCRTextResult *> *)recognizeText:(UIImage *)image {
  return [self
      recognizeText:image
           inRegion:CGRectMake(0, 0, image.size.width, image.size.height)];
}

- (NSArray<FBOCRTextResult *> *)recognizeText:(UIImage *)image
                                     inRegion:(CGRect)region {
  NSMutableArray *results = [NSMutableArray array];

  CGImageRef cgImage = image.CGImage;
  if (!cgImage)
    return results;

  VNRecognizeTextRequest *request = [[VNRecognizeTextRequest alloc]
      initWithCompletionHandler:^(VNRequest *_Nonnull request,
                                  NSError *_Nullable error) {
        if (error) {
          NSLog(@"OCR Error: %@", error);
          return;
        }

        for (VNRecognizedTextObservation *observation in request.results) {
          VNRecognizedText *text = [observation topCandidates:1].firstObject;
          if (!text)
            continue;

          // Convert normalized coordinates to pixel coordinates
          CGRect boundingBox = observation.boundingBox;
          // Vision origin is bottom-left, UIKit is top-left
          // Normalized rect: x, y, w, h

          CGFloat w = boundingBox.size.width * image.size.width;
          CGFloat h = boundingBox.size.height * image.size.height;
          CGFloat x = boundingBox.origin.x * image.size.width;
          // Flip Y coordinate
          CGFloat y = (1.0 - boundingBox.origin.y - boundingBox.size.height) *
                      image.size.height;

          // Filter by region if necessary (simple intersection check)
          CGRect boxFn = CGRectMake(x, y, w, h);

          // Only return if it intersects with our ROI (if ROI is the whole
          // image, it always intersects)
          // ... simple implementation assumes ROI cropping done before or
          // checking here For now, let's just return all found text, assuming
          // client handles filtering or we crop image before

          FBOCRTextResult *res =
              [[FBOCRTextResult alloc] initWithText:text.string
                                         confidence:text.confidence
                                               rect:boxFn];
          [results addObject:res];
        }
      }];

  request.recognitionLevel = VNRequestTextRecognitionLevelAccurate;
  request.usesLanguageCorrection = YES;

  VNImageRequestHandler *handler =
      [[VNImageRequestHandler alloc] initWithCGImage:cgImage options:@{}];
  NSError *reqError;
  [handler performRequests:@[ request ] error:&reqError];

  return results;
}

- (FBOCRTextResult *)findText:(NSString *)text inImage:(UIImage *)image {
  NSArray *allResults = [self recognizeText:image];
  for (FBOCRTextResult *res in allResults) {
    if ([res.text containsString:text]) {
      return res;
    }
  }
  return nil;
}

- (NSDictionary *)findImage:(UIImage *)templateImage
                    inImage:(UIImage *)image
                  threshold:(float)threshold {
  // Template matching requires OpenCV which might be missing or hard to link in
  // this emergency fix. Returning nil for now to allow compilation.
  // TODO: Re-implement with OpenCV if needed.
  return nil;
}

@end
