{"type":"message","id":"535df346","parentId":"09b9c0ac","timestamp":"2026-04-07T12:29:34.964Z","message":{"role":"toolResult","toolCallId":"call_9ca107bc0743d750","toolName":"exec","content":[{"type":"text","text":"'User-Agent: openclaw-lark/2026.4.1/mac\\r\\n' +\n        'Content-Length: 20\\r\\n' +\n        'Accept-Encoding: gzip, compress, deflate, br\\r\\n' +\n        'Host: open.feishu.cn\\r\\n' +\n        'Connection: keep-alive\\r\\n' +\n        '\\r\\n',\n      _keepAliveTimeout: 0,\n--\n      parser: null,\n      maxHeadersCount: null,\n      reusedSocket: true,\n      host: 'open.feishu.cn',\n      protocol: 'https:',\n      _redirectable: [Writable],\n      Symbol(shapeMode): false,\n--\n      validateStatus: [Function: validateStatus],\n      headers: [Object [AxiosHeaders]],\n      method: 'post',\n      url: 'https://open.feishu.cn/open-apis/bot/v1/openclaw_bot/ping',\n      data: '{\"needBotInfo\":true}',\n      params: {},\n      allowAbsoluteUrls: true\n--\n        'User-Agent: openclaw-lark/2026.4.1/mac\\r\\n' +\n        'Content-Length: 20\\r\\n' +\n        'Accept-Encoding: gzip, compress, deflate, br\\r\\n' +\n        'Host: open.feishu.cn\\r\\n' +\n        'Connection: keep-alive\\r\\n' +\n        '\\r\\n',\n      _keepAliveTimeout: 0,\n--\n      parser: null,\n      maxHeadersCount: null,\n      reusedSocket: true,\n      host: 'open.feishu.cn',\n      protocol: 'https:',\n      _redirectable: [Writable],\n      Symbol(shapeMode): false,"}],"details":{"status":"completed","exitCode":0,"durationMs":21,"aggregated":"'User-Agent: openclaw-lark/2026.4.1/mac\\r\\n' +\n        'Content-Length: 20\\r\\n' +\n        'Accept-Encoding: gzip, compress, deflate, br\\r\\n' +\n        'Host: open.feishu.cn\\r\\n' +\n        'Connection: keep-alive\\r\\n' +\n        '\\r\\n',\n      _keepAliveTimeout: 0,\n--\n      parser: null,\n      maxHeadersCount: null,\n      reusedSocket: true,\n      host: 'open.feishu.cn',\n      protocol: 'https:',\n      _redirect