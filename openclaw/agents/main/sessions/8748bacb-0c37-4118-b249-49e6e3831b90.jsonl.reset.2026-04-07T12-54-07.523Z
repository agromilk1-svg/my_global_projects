ecute('SELECT device_udid FROM ec_admin_devices WHERE admin_id = ?', (admin_id,))\n        logger.error(f\"Error getting admin devices: {e}\")\ndef get_device_admin_map() -> dict:\n                SELECT d.device_udid, a.username \n                FROM ec_admin_devices d \n                SELECT t.*, d.device_no\n                LEFT JOIN ec_devices d ON t.udid = d.udid","cwd":"/Users/hh/.openclaw/workspace"},"isError":false,"timestamp":1775556988430}}
