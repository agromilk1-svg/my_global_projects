{"type":"message","id":"c513aac0","parentId":"6d4f3e90","timestamp":"2026-04-07T11:17:30.016Z","message":{"role":"toolResult","toolCallId":"call_86e7c58118c605ef","toolName":"exec","content":[{"type":"text","text":"[channels] bundled channel entry feishu missing bundled-channel-entry contract from /Users/hh/.npm-global/lib/node_modules/openclaw/dist/extensions/feishu/index.js; skipping\nScheduled LaunchAgent restart: gui/501/ai.openclaw.gateway\nrestart scheduled, gateway will restart momentarily"}],"details":{"status":"completed","exitCode":0,"durationMs":7890,"aggregated":"[channels] bundled channel entry feishu missing bundled-channel-entry contract from /Users/hh/.npm-global/lib/node_modules/openclaw/dist/extensions/feishu/index.js; skipping\nScheduled LaunchAgent restart: gui/501/ai.openclaw.gateway\nrestart scheduled, gateway will restart momentarily","cwd":"/Users/hh/.openclaw/workspace"},"isError":false,"timestamp":1775560650010}}
