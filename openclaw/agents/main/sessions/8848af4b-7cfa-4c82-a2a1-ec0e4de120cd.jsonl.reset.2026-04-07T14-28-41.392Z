ktop/my/web_control_center/venv/lib/python3.9/site-packages/xmod-1.8.1.dist-info:\nINSTALLER\nLICENSE\nMETADATA\nRECORD\nWHEEL\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xompletions:\n_xonsh.py\ncd.py\ngh.py\npip.py\nrmdir.py\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh:\n__init__.py\n__main__.py\naliases.py\nansi_colors.py\napi\nbuilt_ins.py\ncli_utils.py\ncodecache.py\ncolor_tools.py\ncommands_cache.py\ncompleter.py\ncompleters\ncompletion_parser_table.py\ncontexts.py\ndirstack.py\nenviron.py\nevents.py\nexecer.py\nforeign_shells.py\nhistory\nimphooks.py\nlazyasd.py\nlazyimps.py\nlazyjson.py\nlib\nmain.py\nparser.py\nparser_table.py\nparsers\nplatform.py\nplatforms\nprocs\nprompt\npyghooks.py\npygments_cache.py\npytest\nshell.py\nshells\nstyle_tools.py\ntimings.py\ntools.py\ntracer.py\nvirtualenv\nwebconfig\nwizard.py\nxonfig.py\nxontribs.py\nxoreutils\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh/api:\n__init__.py\nos.py\nsubprocess.py\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh/completers:\n__init__.py\n_aliases.py\nbase.py\nbash.py\nbash_completion.py\ncommands.py\ncompleter.py\ndirs.py\nenvironment.py\nimports.py\ninit.py\nman.py\npath.py\npython.py\ntools.py\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh/history:\n__init__.py\nbase.py\ndiff_history.py\ndummy.py\njson.py\nmain.py\nsqlite.py\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh/lib:\n__init__.py\ncollections.py\ninspectors.py\nitertools.py\njsonutils.py\nlazyasd.py\nlazyimps.py\nlazyjson.py\nmodules.py\nopenpy.py\nos.py\npretty.py\nsubprocess.py\n\n/Users/hh/Desktop/my/web_control_center/venv/lib/python3.9/site-packages/xonsh/parsers:\n__init__.py\nast.py\nbase.py\ncompletion_context.py\ncontext_check.py\nfstring_adaptor.py\nlexer.py\nply\nrd_parser.py\ntokenize.py\nv310.py\nv313.py\nv36.py\