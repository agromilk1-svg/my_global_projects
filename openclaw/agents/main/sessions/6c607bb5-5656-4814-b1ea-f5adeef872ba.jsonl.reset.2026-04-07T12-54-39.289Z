{"type":"message","id":"f08af69f","parentId":"ed109eb0","timestamp":"2026-04-07T10:32:36.807Z","message":{"role":"assistant","content":[{"type":"text","text":"**Refining Bot Interaction Logic**\n\nI've identified a `NoneType` error in my Feishu listener script, likely caused by `json.loads(m.get(\"content\"))` when the content is empty. 🦞 I'm going to update the script to handle missing content more gracefully, and I'll also add more detailed error logging to help debug any further issues.\n\n\n"},{"type":"toolCall","id":"call_3e8aa768efb409ba","name":"write","arguments":{"path":"/Users/hh/projects/feishu-integration/auto_reply_bot.py","content":"print(\"⚡️ Python script pre-entry...\")\nimport os\nimport requests\nimport json\nimport time\n\n# 常量\nAPP_ID = \"cli_a95e7a8914ba5cc2\"\nAPP_SECRET = \"FnzZDL7YmMnFB2Pr1rXovcitjz6Cv13V\"\n\ndef get_tenant_access_token():\n    url = \"https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal\"\n    data = {\"app_id\": APP_ID, \"app_secret\": APP_SECRET}\n    res = requests.post(url, json=data).json()\n    return res.get(\"tenant_access_token\")\n\ndef send_reply(token, msg_id, content):\n    url = f\"https://open.feishu.cn/open-apis/im/v1/messages/{msg_id}/reply\"\n    headers = {\"Authorization\": f\"Bearer {token}\", \"Content-Type\": \"application/json\"}\n    data = {\"msg_type\": \"text\", \"content\": json.dumps({\"text\": content})}\n    r = requests.post(url, headers=headers, json=data)\n    if r.status_code != 200 or r.json().get(\"code\") != 0:\n        print(f\"❌ 回复回复失败: {r.text}\")\n\ndef poll_and_auto_reply():\n    print(\"🦞 龙虾飞书自动对话引擎已启动...\")\n    last_processed_time = int(time.time() * 1000)\n    \n    while True:\n        try:\n            token = get_tenant_access_token()\n            # 获取所有群组中的消息\n            # 为简单起见，我们先列出最近的消息\n            chats_url = \"https://open.feishu.cn/open-apis/im/v1/chats\"\n            headers = {\"Authorization\": f\"Bearer {token}\"}\n            chats_res = requests.get(chats_url, headers=headers).json()\n            \n            if chats_res.get(\"code\") == 0:\n                for chat in chats_res.get(\"data\", {}).get(\"items\", []):\n                    chat_id = chat[\"chat_id\"]\n                    msgs_url = f\"https://open.feishu.cn/open-apis/im/v1/messages?container_id_type=chat&container_id={chat_id}\"\n                    msg_data = requests.get(msgs_url, headers=headers).json()\n                    \n                    for m in msg_data.get(\"data\", {}).get(\"items\", []):\n                        m_time = int(m.get(\"create_time\"))\n                        if m_time > last_processed_time and m.get(\"sender\", {}).get(\"sender_type\") == \"user\":\n                            content_raw = m.get(\"content\")\n                            if not content_raw:\n                                continue\n                                \n                            try:\n                                user_text = json.loads(content_raw).get(\"text\", \"\")\n                            except:\n                                user_text = \"[非文本消息]\"\n\n                            msg_id = m.get(\"message_id\")\n                            print(f\"💬 收到从群 [{chat.get('name')}] 的指令: {user_text}\")\n                            \n                            reply_text = f\"【龙虾复活号】收到指令：『{user_text}』。大圣，我已经强制突破了插件限制，现在能看到您说话了！🦞\"\n                            send_reply(token, msg_id, reply_text)\n                            print(f\"✅ 已成功回复飞书消息\")\n                            \n                            last_processed_time = m_time\n            \n            time.sleep(2)\n        except Exception as e:\n            print(f\"⚠️ 飞书监听异常: {type(e).__name__}: {e}\")\n            time.sleep(5)\n\nif __name__ == \"__main__\":\n    print(\"🚀 Script starting...\")\n    poll_and_auto_reply()\n"}}],"api":"openai-completions","provider":"custom","model":"gemini-3-flash-agent","usage":{"input":26916,"output":1051,"cacheRead":72438,"cacheWrite":0,"totalTokens":100405,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775557948436,"responseId":"chatcmpl-6790061b-64d4-44d3-8624-e7e38a9bf873"}}
